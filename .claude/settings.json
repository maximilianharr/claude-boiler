{
  "theme": "dark",
  "model": "haiku",
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline-command.sh"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash",
      "Agent",
      "WebFetch",
      "WebSearch",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(git status)",
      "Bash(git add .)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Bash(rm -rf *",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(docker rm *)",
      "Bash(DROP TABLE *)",
      "Bash(sudo *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "paplay /usr/share/sounds/freedesktop/stereo/bell.oga 2>/dev/null"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "paplay /usr/share/sounds/freedesktop/stereo/bell.oga 2>/dev/null"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "paplay /usr/share/sounds/freedesktop/stereo/bell.oga 2>/dev/null"
          }
        ]
      }
    ]
  }
}
